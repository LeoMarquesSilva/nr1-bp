# Supabase (obrigatório para envio e listagem dos diagnósticos).
# Obtenha em: https://supabase.com/dashboard → seu projeto → Settings → API
# Vercel: use só variáveis VITE_* para o app — elas entram no JavaScript público do browser.
# Não defina chave service_role (nem qualquer segredo) com prefixo VITE_.
# Preview/Production: confira o mesmo project_ref (URL) em todos os ambientes que devem falar com o mesmo banco.
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key
# Só para scripts locais (create-admin-users, nunca no bundle do Vite). Não commite.
# SUPABASE_SERVICE_ROLE_KEY=
# Lista JSON de administradores: copie scripts/admin-seed.example.json → admin-seed.local.json na raiz, ou defina caminho abaixo.
# ADMIN_SEED_FILE=admin-seed.local.json

# URL pública do site (sem barra final). Usada no build para canonical, Open Graph e JSON-LD.
# Ex.: https://www.confiara.com.br
VITE_PUBLIC_SITE_URL=

# Multi-tenant: identifique cada empresa/cliente para isolar os dados.
# Use um valor único por cliente (ex.: slug ou UUID). Sem isso, usa "default".
VITE_TENANT_ID=default

# White-label (opcional): cada cliente vê o próprio nome e logo.
# Se não definir, aparece "Bismarchi Pires Sociedade de Advogados" e /logo.png
VITE_APP_NAME=Bismarchi Pires Sociedade de Advogados
VITE_APP_LOGO_URL=/logo.png
VITE_PRODUCT_NAME=Diagnóstico HSE-IT
